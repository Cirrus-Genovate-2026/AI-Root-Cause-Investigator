# GitHub API Token (create at https://github.com/settings/tokens)
# Requires: repo, read:repo_hook, read:actions scopes
GITHUB_TOKEN=your_github_token_here

# GitHub Repository (format: owner/repo)
# Example: microsoft/vscode or your-username/your-repo
GITHUB_REPO=owner/repo

# AWS Configuration (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Postman Configuration (optional)
POSTMAN_API_KEY=your_postman_api_key
POSTMAN_WORKSPACE_ID=your_workspace_id

# OpenAI Configuration (optional)
OPENAI_API_KEY=your_openai_api_key
