## Copy this file to `.env` and fill credentials before running
# GitHub
GITHUB_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# AWS (standard AWS env vars or configure profile)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure: use DefaultAzureCredential (login via az) or set env vars
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Postman (if using Postman API)
POSTMAN_API_KEY=